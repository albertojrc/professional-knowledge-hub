{
  "name": "professional-knowledge-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Professional Knowledge Hub for Data Science, Banking, Finance, Economics, Management and Analytics.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "qa:audit": "node scripts/qa-audit.mjs",
    "qa:sprint29": "node scripts/qa-sprint-2-9.mjs",
    "qa:sprint210": "node scripts/qa-sprint-2-10.mjs",
    "validate": "npm run qa:audit && npm run qa:sprint29 && npm run qa:sprint210 && npm run lint && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "6.0.5",
    "typescript": "5.7.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.14.0",
    "typescript-eslint": "8.18.2"
  }
}
